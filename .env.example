# TCP socket — receives raw TMI1910 fixed-width strings
TCP_PORT=3004
TCP_HOST=0.0.0.0

# MSG_LENGTH: 0 = newline-delimited (for testing with nc)
#             1365 = real TMI1910 fixed-length framing
MSG_LENGTH=0

# Tazama TMS endpoint
TMS_ENDPOINT=http://localhost:5000

# Tenant ID for Tazama multi-tenancy
TENANT_ID=DEFAULT

# Timezone offset applied when parsing remote_time_sent (NBP/PKT = +05:00)
TIMEZONE_OFFSET=+05:00

# TMS auth
AUTHENTICATED=false
AUTH_TOKEN=

# PostgreSQL evaluation database (Tazama Docker default port = 15432)
DB_HOST=localhost
DB_PORT=15432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=evaluation

# How long to wait for evaluation result after TMS submission
POLL_TIMEOUT_MS=10000
POLL_INTERVAL_MS=500
