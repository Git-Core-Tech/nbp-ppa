# HTTP server
PORT=3003

# TCP socket (receives raw TMI1910 fixed-width strings)
TCP_PORT=3004
TCP_HOST=0.0.0.0

# MSG_LENGTH: 0 = newline-delimited (for testing with nc/Postman)
#             1365 = real TMI1910 fixed-length framing
MSG_LENGTH=1365

# Tazama TMS endpoint (Full-Stack-Docker-Tazama default: 10.0.110.120:5000)
TMS_ENDPOINT=http://10.0.110.120:5000
TMS_REQUEST_TIMEOUT_MS=10000

# Tenant ID for Tazama multi-tenancy
TENANT_ID=DEFAULT

# Timezone offset applied when parsing remote_time_sent (NBP/PKT = +05:00)
TIMEZONE_OFFSET=+05:00

# TMS auth (set AUTHENTICATED=true and provide AUTH_TOKEN if TMS requires JWT)
AUTHENTICATED=false
AUTH_TOKEN=

TMI_INPUT_MODE=trace