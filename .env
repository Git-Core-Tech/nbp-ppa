# Server
PORT=3003

# Tazama TMS endpoint (Full-Stack-Docker-Tazama default: localhost:5000)
TMS_ENDPOINT=http://localhost:5000

# Tenant ID for Tazama multi-tenancy
TENANT_ID=DEFAULT

# Timezone offset for remote_time_sent parsing (NBP/PKT = +05:00)
TIMEZONE_OFFSET=+05:00

# Set to true if TMS requires a JWT Authorization header
AUTHENTICATED=false
AUTH_TOKEN=
